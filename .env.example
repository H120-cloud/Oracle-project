# Database
DATABASE_URL=postgresql://oracle:oracle_secret@db:5432/oracle_db

# Redis
REDIS_URL=redis://redis:6379/0

# App
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Market Data
MARKET_DATA_PROVIDER=yfinance

# Scanner
SCANNER_TOP_N=20
SCANNER_MIN_PRICE=1.00
SCANNER_MAX_PRICE=500.00
SCANNER_MIN_VOLUME=500000

# Signal
SIGNAL_EXPIRY_MINUTES=30

# V10: Alpaca API (free at https://app.alpaca.markets/signup)
# Enables real-time market data + paper trading execution
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# V10: Paper Trading
PAPER_TRADING_ENABLED=true
PAPER_TRADING_USE_ALPACA=false
